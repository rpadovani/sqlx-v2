FROM golang:1.24-bookworm

# Install clang and llvm for msan (-msan requires llvm/clang)
RUN apt-get update && apt-get install -y clang llvm && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download

COPY . .

# Environment setup
ENV CGO_ENABLED=1

# Provide an entrypoint that will run the fuzzer script
ENTRYPOINT ["./scripts/run_fuzz.sh"]
